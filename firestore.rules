rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Private user profile — only the owner can read/write.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Private per-user scores — only the owner can read/write.
    match /scores/{uid}/games/{gameId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Public leaderboard — anyone can read; a user may only write their own
    // entry, and the score must be a number.
    match /leaderboard/{gameId}/entries/{uid} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.data.score is number;
    }

    // ---- v2 economy (server-authoritative; real money) --------------------
    // Clients may READ their own wallet + ledger, but NEVER write them. All
    // balance changes go through Admin-SDK serverless functions (which bypass
    // these rules). Pool/counters are fully private.
    match /wallets/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    match /ledger/{uid}/entries/{entryId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    match /rewardPool/{docId} {
      allow read, write: if false;
    }
    match /adCounters/{docId} {
      allow read, write: if false;
    }

    // Daily streak state — owner reads; server (Admin) writes.
    match /streaks/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
