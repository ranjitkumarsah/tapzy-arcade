# =============================================================================
# Tapzy Arcade — environment variables
# Copy this file to `.env` for local dev. NEVER commit the real `.env`.
# In production, set these in the Vercel dashboard (Settings → Environment Variables).
# =============================================================================

# --- Firebase public client config (Phase 2) -------------------------------
# These are PUBLIC (safe in the client bundle) — protected by Firestore rules.
# The VITE_ prefix exposes them to the frontend.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Monetag (Phase 6) ------------------------------------------------------
VITE_MONETAG_ZONE_ID=

# =============================================================================
# SERVER-SIDE SECRETS — set ONLY in the Vercel dashboard, never with a VITE_
# prefix, never in this repo. Listed here for documentation only.
# =============================================================================
# TELEGRAM_BOT_TOKEN=        # from BotFather (Phase 0). Used by /api/verifyTelegramAuth.
# FIREBASE_SERVICE_ACCOUNT=  # full service-account JSON (Phase 2). Used to mint custom tokens.
